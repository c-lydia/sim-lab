### General Purpose .gitignore ###
# VS Code settings
.vscode/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.env
*.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebooks
.ipynb_checkpoints/

# MATLAB/Octave
*.asv
*.m~
*.mat
*.fig
*.mex*

# Data files
data/
*.csv
*.tsv
*.xls
*.xlsx
*.h5
*.hdf5
*.json
*.xml
*.db
*.sqlite

# Plots and images
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf

# Build outputs
build/
dist/
*.o
*.obj
*.so
*.dll
*.exe
*.out

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
Desktop.ini

# Backup files
*~
*.bak
*.tmp

# Docker
*.log
docker-compose.override.yml
